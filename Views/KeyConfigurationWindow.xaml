<Window x:Class="WpfApp.Views.KeyConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:WpfApp.Behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:viewModels="clr-namespace:WpfApp.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:KeyConfigurationDialogViewModel}"
        Title="编辑按键配置"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 内容区 -->
        <Grid Grid.Row="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 基本信息区 -->
            <Border Grid.Row="0"
                    Background="#F9F9F9"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 配置名称 -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="按键名称:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:TextBox Grid.Row="0" Grid.Column="1"
                                        hc:InfoElement.ShowClearButton="True"
                                        Text="{Binding ConfigurationName, UpdateSourceTrigger=PropertyChanged}"
                                        hc:InfoElement.Placeholder="请输入配置名称"
                                        Margin="0,0,16,8"/>

                            <!-- 按键模式 -->
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="按键模式:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Grid.Row="0" Grid.Column="3"
                                      ItemsSource="{Binding ExecutionModes}"
                                      SelectedItem="{Binding SelectedExecutionMode}"
                                      Style="{StaticResource ComboBoxExtend}"
                                      Margin="0,0,0,8"/>

                            <!-- 激活热键 -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="激活:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:TextBox Grid.Row="1" Grid.Column="1"
                                        hc:InfoElement.ShowClearButton="True"
                                        Text="{Binding StartHotkeyText, UpdateSourceTrigger=PropertyChanged}"
                                        hc:InfoElement.Placeholder="点击此处捕获激活热键"
                                        PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                                        PreviewTextInput="PreventTextInput"
                                        Tag="Start"
                                        Margin="0,0,16,8"
                                        IsUndoEnabled="False"/>

                            <!-- 停止热键 -->
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="停止:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:TextBox Grid.Row="1" Grid.Column="3"
                                        hc:InfoElement.ShowClearButton="True"
                                        Text="{Binding StopHotkeyText, UpdateSourceTrigger=PropertyChanged}"
                                        hc:InfoElement.Placeholder="点击此处捕获停止热键"
                                        PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                                        PreviewTextInput="PreventTextInput"
                                        Tag="Stop"
                                        Margin="0,0,0,8"
                                        IsUndoEnabled="False"/>

                            <!-- 默认延迟 -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="默认延迟:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1"
                                              Value="{Binding DefaultInterval}"
                                              Minimum="0"
                                              Maximum="10000"
                                              Style="{StaticResource NumericUpDownExtend}"
                                              Margin="0,0,16,8"
                                              ToolTip="新添加按键/坐标时使用的默认间隔时间(ms)"/>

                            <!-- 默认按压时长 -->
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="按压时长:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="3"
                                              Value="{Binding DefaultHoldDuration}"
                                              Minimum="0"
                                              Maximum="10000"
                                              Style="{StaticResource NumericUpDownExtend}"
                                              Margin="0,0,0,8"
                                              ToolTip="新添加按键/坐标时使用的默认按压时长(ms)，0表示仅点击不按压"/>

                            <!-- 功能开关 -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                                        Orientation="Horizontal">
                                <CheckBox Content="降低卡位"
                                          IsChecked="{Binding IsReduceKeyStuck}"
                                          Style="{StaticResource CheckBoxBaseStyle}"
                                          Margin="0,0,16,0"
                                          ToolTip="启用后，程序将在按键之间添加微小延迟，减少按键卡顿现象"/>
                                <CheckBox Content="声音提示"
                                          IsChecked="{Binding SoundEnabled}"
                                          Style="{StaticResource CheckBoxBaseStyle}"
                                          Margin="0,0,8,0"
                                          ToolTip="启用后，按键执行时会播放音效提示"/>
                                <Button x:Name="btnSoundVolumeSettings"
                                        Style="{StaticResource CircleButtonStyle}"
                                        Width="24" Height="24"
                                        Margin="0,0,16,0"
                                        Click="SoundVolumeSettings_Click"
                                        ToolTip="音量设置">
                                    <Path Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.85 14,18.71V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z"
                                          Fill="#707070"
                                          Width="14" Height="14"
                                          Stretch="Uniform"/>
                                </Button>
                                <CheckBox Content="切换输入法"
                                          IsChecked="{Binding AutoSwitchIME}"
                                          Style="{StaticResource CheckBoxBaseStyle}"
                                          ToolTip="启用后，执行按键时自动切换到英文输入法，执行完成后恢复"/>
                            </StackPanel>
                        </Grid>
            </Border>

            <!-- 音量设置浮窗 -->
            <Popup x:Name="soundVolumePopup"
                           PlacementTarget="{Binding ElementName=btnSoundVolumeSettings}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <Grid Width="240">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 音量控制 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 音量滑动条 -->
                                    <Slider Grid.Column="1"
                                            x:Name="volumeSlider"
                                            Style="{StaticResource VolumeSliderStyle}"
                                            Minimum="0"
                                            Maximum="1"
                                            SmallChange="0.01"
                                            LargeChange="0.1"
                                            Margin="0,0,8,0"
                                            Value="{Binding SoundVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalAlignment="Center" />

                                    <!-- 当前音量百分比文本 -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SoundVolume, StringFormat={}{0:P0}}"
                                               Width="40"
                                               Foreground="#505050"
                                               FontSize="12"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- 提示文本 -->
                                <TextBlock Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="#707070"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="调整按键执行时的音效音量" />
                            </Grid>
                        </Border>
            </Popup>

            <!-- 添加按键/坐标区 -->
            <Border Grid.Row="1"
                    Background="#F9F9F9"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,12">
                        <StackPanel>
                            <!-- 按键输入区域 -->
                            <DockPanel x:Name="KeyInputArea"
                                       Height="35"
                                       Margin="0,0,0,8">
                                <!-- 按键/坐标模式切换按钮 -->
                                <Button x:Name="btnToggleCoordinateMode"
                                        Style="{StaticResource SVGCircleButtonStyle}"
                                        Width="32" Height="32"
                                        DockPanel.Dock="Left"
                                        Margin="0,0,10,0"
                                        Click="ToggleCoordinateMode_Click"
                                        ToolTip="切换到鼠标坐标模式">
                                    <svgc:SvgViewbox Source="pack://application:,,,/Resource/svg/边牧.svg"
                                                    Width="20"
                                                    Height="20"
                                                    Stretch="Uniform">
                                        <svgc:SvgViewbox.Resources>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill"
                                                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            </Style>
                                        </svgc:SvgViewbox.Resources>
                                    </svgc:SvgViewbox>
                                </Button>

                                <!-- 添加按键按钮 -->
                                <Button Style="{StaticResource RoundedShadowButtonSmall}"
                                        Command="{Binding AddKeyCommand}"
                                        Width="95" Height="35"
                                        DockPanel.Dock="Left"
                                        Margin="0,0,10,0"
                                        ToolTip="添加当前按键">
                                    <DockPanel>
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Width="16" Height="16"
                                              Stretch="Uniform"
                                              Margin="0,0,8,0" />
                                        <TextBlock Text="添加按键"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Button>

                                <!-- 按键输入框 -->
                                <TextBox x:Name="KeyInputBox"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding CurrentKeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewKeyDown="KeyInput_PreviewKeyDown"
                                         PreviewMouseDown="KeyInputBox_PreviewMouseDown"
                                         TextAlignment="Center"
                                         Tag="点此输入按键"
                                         IsReadOnly="True"
                                         IsUndoEnabled="False"
                                         CaretBrush="Transparent" />
                            </DockPanel>

                            <!-- 坐标输入区域 -->
                            <Grid x:Name="CoordinateInputArea"
                                  Height="35"
                                  Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- 切换按钮 -->
                                    <ColumnDefinition Width="Auto"/> <!-- 添加坐标按钮 -->
                                    <ColumnDefinition Width="Auto"/> <!-- X坐标输入框 -->
                                    <ColumnDefinition Width="Auto"/> <!-- 逗号分隔符 -->
                                    <ColumnDefinition Width="Auto"/> <!-- Y坐标输入框 -->
                                    <ColumnDefinition Width="40"/> <!-- 鼠标图标按钮 -->
                                    <ColumnDefinition Width="*"/> <!-- 占位 -->
                                </Grid.ColumnDefinitions>

                                <!-- 按键/坐标模式切换按钮 -->
                                <Button x:Name="btnToggleKeyMode"
                                        Style="{StaticResource SVGCircleButtonStyle}"
                                        Width="32" Height="32"
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        Click="ToggleCoordinateMode_Click"
                                        ToolTip="切换到按键模式">
                                    <svgc:SvgViewbox Source="pack://application:,,,/Resource/svg/三花猫.svg"
                                                    Width="20"
                                                    Height="20"
                                                    Stretch="Uniform">
                                        <svgc:SvgViewbox.Resources>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill"
                                                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            </Style>
                                        </svgc:SvgViewbox.Resources>
                                    </svgc:SvgViewbox>
                                </Button>

                                <!-- 添加坐标按钮 -->
                                <Button Style="{StaticResource RoundedShadowButtonSmall}"
                                        Width="95" Height="35"
                                        Grid.Column="1"
                                        Margin="0,0,10,0"
                                        Click="AddCoordinate_Click"
                                        ToolTip="添加当前坐标">
                                    <DockPanel>
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Width="16" Height="16"
                                              Stretch="Uniform"
                                              Margin="0,0,8,0" />
                                        <TextBlock Text="添加坐标"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Button>

                                <!-- X坐标输入框 -->
                                <TextBox x:Name="XCoordinateInputBox"
                                         Grid.Column="2"
                                         Style="{StaticResource ModernTextBox}"
                                         Width="80"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Center"
                                         PreviewTextInput="NumberValidationTextBox"
                                         GotFocus="NumberInput_GotFocus"
                                         LostFocus="NumberInput_LostFocus"
                                         Tag="X"
                                         ToolTip="X坐标" />

                                <!-- 逗号分隔符 -->
                                <TextBlock Grid.Column="3"
                                           Text=","
                                           FontSize="16"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="5,0" />

                                <!-- Y坐标输入框 -->
                                <TextBox x:Name="YCoordinateInputBox"
                                         Grid.Column="4"
                                         Style="{StaticResource ModernTextBox}"
                                         Width="80"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Center"
                                         PreviewTextInput="NumberValidationTextBox"
                                         GotFocus="NumberInput_GotFocus"
                                         LostFocus="NumberInput_LostFocus"
                                         Tag="Y"
                                         ToolTip="Y坐标" />

                                <!-- 鼠标图标按钮 -->
                                <Button x:Name="btnMouseIcon"
                                        Style="{StaticResource CircleButtonStyle}"
                                        Width="32" Height="32"
                                        Grid.Column="5"
                                        Margin="10,0,0,0"
                                        ToolTip="点击进入坐标编辑模式，或拖拽到目标位置捕获坐标">
                                    <Path Data="M232.709086 206.759841c-2.60747-35.250013 23.854905-65.939497 59.104918-68.546967a64 64 0 0 1 40.722649 10.911364L820.601501 481.195232c29.223558 19.883232 36.796185 59.691514 16.912954 88.916203a64 64 0 0 1-41.781687 27.021845L661.499479 620.842384l86.876115 150.473748c17.496159 30.305201 7.391788 68.970808-22.513307 86.888548l-0.912106 0.536865-73.900927 42.666667c-30.610366 17.673607-69.751806 7.184954-87.424283-23.425413l-86.878375-150.473748-87.64694 104.393748c-22.500874 26.800318-62.292203 30.517687-89.352477 8.536724l-0.816036-0.674755a64 64 0 0 1-22.672671-44.293086l-43.548256-588.711841z m88.360124 37.772715l36.418684 492.312301 73.491779-87.531656a64 64 0 0 1 16.24272-13.820609l0.771956-0.452098c30.611497-17.673607 69.752936-7.184954 87.425413 23.425413l91.436644 158.375276 36.951029-21.333333-91.436645-158.375276a64 64 0 0 1-7.436998-19.988344l-0.161624-0.879329c-6.148521-34.808088 17.084751-68.008971 51.891708-74.156362l112.550711-19.880972-408.145377-277.695011z"
                                          Fill="#707070"
                                          Width="20" Height="20"
                                          Stretch="Uniform" />
                                </Button>
                            </Grid>
                </StackPanel>
            </Border>

            <!-- 按键列表 -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4">
                <ListView ItemsSource="{Binding KeyItems}"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="12"
                          Style="{StaticResource ListView.Small}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="50" Header="序号">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Converter={StaticResource IndexConverter}}"
                                                           FontSize="12"
                                                           FontWeight="Medium"
                                                           Foreground="#666666"
                                                           HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="60" Header="删除">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CircleButtonStyle}"
                                                        Width="24" Height="24"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <i:Interaction.Behaviors>
                                                        <behaviors:DeleteConfirmationBehavior ConfirmTimeout="3">
                                                            <behaviors:DeleteConfirmationBehavior.ConfirmedCommand>
                                                                <Binding Path="DataContext.DeleteKeyCommand" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </behaviors:DeleteConfirmationBehavior.ConfirmedCommand>
                                                            <behaviors:DeleteConfirmationBehavior.CommandParameter>
                                                                <Binding Path="."/>
                                                            </behaviors:DeleteConfirmationBehavior.CommandParameter>
                                                        </behaviors:DeleteConfirmationBehavior>
                                                    </i:Interaction.Behaviors>
                                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          Width="12" Height="12"
                                                          Stretch="Uniform"/>
                                                    <Button.ToolTip>
                                                        <ToolTip>
                                                            <TextBlock Text="删除此按键" />
                                                        </ToolTip>
                                                    </Button.ToolTip>
                                                </Button>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="200" Header="名称" DisplayMemberBinding="{Binding DisplayName}"/>

                                    <GridViewColumn Width="120" Header="延迟">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Value="{Binding KeyInterval}"
                                                                  Minimum="0"
                                                                  Maximum="10000"
                                                                  Width="100"
                                                                  Style="{StaticResource NumericUpDownExtend}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="120" Header="按压时长">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Value="{Binding HoldDuration}"
                                                                  Minimum="0"
                                                                  Maximum="10000"
                                                                  Width="100">
                                                    <hc:NumericUpDown.Style>
                                                        <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDownExtend}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Coordinates">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="坐标移动不支持按压时长"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </hc:NumericUpDown.Style>
                                                </hc:NumericUpDown>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="60" Header="开关">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Style="{StaticResource CheckBoxBaseStyle}"
                                                          HorizontalAlignment="Center"
                                                          ToolTip="启用/禁用此按键"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>

                            <!-- 右键菜单 -->
                            <ListView.ContextMenu>
                                    <ContextMenu Style="{StaticResource ContextMenu.Small}">
                                        <MenuItem Header="添加按键"
                                                  Command="{Binding AddKeyCommand}">
                                            <MenuItem.Icon>
                                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                                      Fill="#4CAF50"
                                                      Width="16" Height="16"
                                                      Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="编辑按键"
                                                  Command="{Binding EditKeyCommand}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                      Fill="#2196F3"
                                                      Width="16" Height="16"
                                                      Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="删除按键"
                                                  Command="{Binding DeleteKeyCommand}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                      Fill="#F44336"
                                                      Width="16" Height="16"
                                                      Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                </ContextMenu>
                            </ListView.ContextMenu>
                </ListView>
            </Border>
        </Grid>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="1"
                Background="#F9F9F9"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16,12">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="取消"
                            Click="CancelButton_Click"
                            Style="{StaticResource ButtonDefault}"
                            Width="100"
                            Margin="0,0,8,0"/>
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
