<Page x:Class="WpfApp.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfApp.Views"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="设置">

    <Page.Resources>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 配置文件管理 -->
        <hc:Card Header="配置文件管理" Margin="0,0,0,20">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Style="{StaticResource ButtonPrimary}"
                            Width="120"
                            Height="35"
                            Margin="0,0,15,0"
                            Command="{Binding ImportConfigCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="导入配置"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ButtonPrimary}"
                            Width="120"
                            Height="35"
                            Command="{Binding ExportConfigCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="导出配置"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </hc:Card>

        <!-- 更新管理 -->
        <hc:Card Grid.Row="1" Header="更新管理" Margin="0,0,0,20">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Style="{StaticResource ButtonPrimary}"
                            Width="120"
                            Height="35"
                            Command="{Binding CheckUpdateCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateStatus}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </hc:Card>

        <!-- 驱动选择 -->
        <hc:Card Grid.Row="2" Header="驱动选择" Margin="0,0,0,20">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <hc:ComboBox SelectedValuePath="Tag"
                                 SelectedValue="{Binding SelectedDriver}"
                                 Width="120"
                                 Margin="0,10,0,0">
                        <ComboBoxItem Content="AHK" Tag="AHK" />
                        <ComboBoxItem Content="LyKeys" Tag="LyKeys" />
                    </hc:ComboBox>
                    <TextBlock Text="{Binding DriverStatus}"
                               Foreground="{Binding DriverStatusColor}"
                               FontFamily="{StaticResource EmojiFont}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,10,0,0" />
                </StackPanel>
            </StackPanel>
        </hc:Card>

        <!-- 调试模式 -->
        <hc:Card Grid.Row="3" Header="调试模式" Margin="0,0,0,20">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Style="{StaticResource ButtonPrimary}"
                            Width="180"
                            Height="35"
                            Command="{Binding ToggleDebugModeCommand}">
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="{Binding DebugModeStatus}"
                                       Foreground="{Binding DebugModeStatusColor}"
                                       FontFamily="{StaticResource EmojiFont}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="注意：开启调试模式会记录更多日志信息，可能会影响性能"
                           Margin="0,10,0,0"
                           Foreground="#666666"
                           FontSize="12" />
            </StackPanel>
        </hc:Card>
    </Grid>
</Page>