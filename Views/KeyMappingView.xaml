<Page x:Class="WpfApp.Views.KeyMappingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:behaviors="clr-namespace:WpfApp.Behaviors"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:viewModels="clr-namespace:WpfApp.ViewModels"
      mc:Ignorable="d"
      Title="按键配置"
      d:DataContext="{d:DesignInstance Type=viewModels:KeyMappingViewModel}">

    <Page.Resources>
        <!-- 操作按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 功能开关组 - 可展开收缩 -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,10">
            <Expander IsExpanded="True"
                      BorderThickness="0"
                      Background="Transparent">
                <Expander.Header>
                    <TextBlock Text="功能开关"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="5,5,0,5" />
                </Expander.Header>

                <!-- 功能开关区域 - 横向布局 -->
                <WrapPanel Orientation="Horizontal"
                           Margin="15,5,0,0">
                    <!-- 热键控制开关 -->
                    <DockPanel Margin="0,0,20,10">
                        <TextBlock Text="热键控制"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0" />
                        <CheckBox Style="{StaticResource ModernSwitch}"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Padding="0,0,0,0"
                                  IsChecked="{Binding IsHotkeyControlEnabled, Mode=TwoWay}"
                                  ToolTip="启用/禁用所有热键响应功能" />
                    </DockPanel>

                    <!-- 状态浮窗 -->
                    <DockPanel Margin="0,0,20,10">
                        <TextBlock Text="状态浮窗"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0" />
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Style="{StaticResource ModernSwitch}"
                                      Height="32"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Left"
                                      Padding="0,0,0,0"
                                      IsChecked="{Binding IsFloatingWindowEnabled, Mode=TwoWay}" />
                            <Button x:Name="btnFloatingOpacitySettings"
                                    Style="{StaticResource CircleButtonStyle}"
                                    Width="24" Height="24"
                                    Margin="3,0,0,0"
                                    Click="FloatingOpacitySettings_Click">
                                <Path
                                    Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                    Fill="#707070"
                                    Width="14" Height="14"
                                    Stretch="Uniform" />
                                <Button.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="透明度设置" />
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <!-- 浮窗透明度设置浮窗 -->
                    <Popup x:Name="floatingOpacityPopup"
                           PlacementTarget="{Binding ElementName=btnFloatingOpacitySettings}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <Grid Width="240">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 透明度控制 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 透明度滑动条 -->
                                    <Slider Grid.Column="1"
                                            x:Name="opacitySlider"
                                            Style="{StaticResource VolumeSliderStyle}"
                                            Minimum="0.1"
                                            Maximum="1"
                                            SmallChange="0.01"
                                            LargeChange="0.1"
                                            Margin="0,0,8,0"
                                            Value="{Binding FloatingWindowOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalAlignment="Center" />

                                    <!-- 当前透明度百分比文本 -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FloatingWindowOpacity, StringFormat={}{0:P0}}"
                                               Width="40"
                                               Foreground="#505050"
                                               FontSize="12"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- 提示文本 -->
                                <TextBlock Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="#707070"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="调整状态浮窗的透明度，数值越小越透明" />
                            </Grid>
                        </Border>
                    </Popup>

                    <!-- 硬件加速 -->
                    <DockPanel Margin="0,0,20,10">
                        <TextBlock Text="硬件加速"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0" />
                        <CheckBox Style="{StaticResource ModernSwitch}"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Padding="0,0,0,0"
                                  IsChecked="{Binding EnableHardwareAcceleration, Mode=TwoWay}"
                                  ToolTip="启用后，程序将使用硬件加速优化渲染性能，重启应用后生效" />
                    </DockPanel>
                </WrapPanel>
            </Expander>
        </Border>

        <!-- 配置列表容器 -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部工具栏 -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 标题 -->
                        <TextBlock Grid.Column="0"
                                   Text="按键列表"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <!-- 操作按钮组 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="添加配置"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding AddConfigurationCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 配置列表 -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Configurations}"
                          SelectedItem="{Binding SelectedConfiguration}"
                          BorderThickness="0"
                          Background="Transparent"
                          Margin="0"
                          Style="{StaticResource ListView.Small}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="50" Header="序号">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Converter={StaticResource IndexConverter}}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#666666"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="60" Header="删除">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource CircleButtonStyle}"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <behaviors:DeleteConfirmationBehavior ConfirmTimeout="3">
                                                <behaviors:DeleteConfirmationBehavior.ConfirmedCommand>
                                                    <Binding Path="DataContext.DeleteConfigurationCommand" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                </behaviors:DeleteConfirmationBehavior.ConfirmedCommand>
                                                <behaviors:DeleteConfirmationBehavior.CommandParameter>
                                                    <Binding Path="Id"/>
                                                </behaviors:DeleteConfirmationBehavior.CommandParameter>
                                            </behaviors:DeleteConfirmationBehavior>
                                        </i:Interaction.Behaviors>
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Width="12" Height="12"
                                              Stretch="Uniform"/>
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="删除此配置" />
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="200" Header="配置名称" DisplayMemberBinding="{Binding Name}"/>

                        <GridViewColumn Width="100" Header="执行模式" DisplayMemberBinding="{Binding ExecutionModeText}"/>

                        <GridViewColumn Width="100" Header="激活热键">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartHotkeyText}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#2196F3"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="100" Header="停止热键">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StopHotkeyText}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#F44336"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="60" Header="开关">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}"
                                              Style="{StaticResource CheckBoxBaseStyle}"
                                              HorizontalAlignment="Center"
                                              ToolTip="启用/禁用此配置"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <!-- 右键菜单 -->
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="编辑配置"
                                  Command="{Binding PlacementTarget.DataContext.EditConfigurationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                      Fill="#2196F3"
                                      Width="16" Height="16"
                                      Stretch="Uniform"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="克隆配置"
                                  Command="{Binding PlacementTarget.DataContext.CloneConfigurationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Id, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                      Fill="#4CAF50"
                                      Width="16" Height="16"
                                      Stretch="Uniform"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ListView.ContextMenu>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Page>
